<?xml version="1.0" encoding="utf-8"?>
<!--
    E68 App Icon — Round Adaptive Icon descriptor
    Place in: res/mipmap-anydpi-v26/ic_launcher_round.xml

    Android uses this on launchers that prefer circular icons.
    The adaptive icon system automatically clips the foreground/background
    into the device's preferred shape (circle, squircle, etc.)
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
