<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_dark"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/text_primary"
            app:title="Новый дефект"
            app:titleCentered="true"
            app:titleTextColor="@color/text_primary"
            app:titleTextAppearance="@style/TextAppearance.E68.Title" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- НАЗВАНИЕ ДЕФЕКТА -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTitle"
                style="@style/Widget.E68.TextInputLayout.Dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Название дефекта"
                app:startIconDrawable="@drawable/ic_warning"
                app:startIconTint="@color/primary"
                app:endIconMode="clear_text"
                app:endIconDrawable="@drawable/ic_close"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ОПИСАНИЕ -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescription"
                style="@style/Widget.E68.TextInputLayout.Dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Описание"
                app:startIconDrawable="@drawable/ic_description"
                app:startIconTint="@color/text_hint"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="3"
                    android:maxLines="6"
                    android:gravity="top"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ТИП ДЕФЕКТА СЕКЦИЯ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Тип дефекта"
                android:textAppearance="@style/TextAppearance.E68.Subtitle"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/defectTypeChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true"
                    app:chipSpacing="8dp" />
            </HorizontalScrollView>

            <!-- СЕРЬЁЗНОСТЬ СЕКЦИЯ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Серьёзность"
                android:textAppearance="@style/TextAppearance.E68.Subtitle"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/severityChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacing="8dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLow"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Низкая"
                    app:chipBackgroundColor="@color/selector_chip_bg_dark"
                    android:textColor="@color/selector_chip_text_dark"
                    app:chipStrokeColor="@color/selector_chip_stroke_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipIconTint="#06D6A0"
                    app:chipIcon="@drawable/ic_circle" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Средняя"
                    android:checked="true"
                    app:chipBackgroundColor="@color/selector_chip_bg_dark"
                    android:textColor="@color/selector_chip_text_dark"
                    app:chipStrokeColor="@color/selector_chip_stroke_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipIconTint="#FFD166"
                    app:chipIcon="@drawable/ic_circle" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHigh"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Высокая"
                    app:chipBackgroundColor="@color/selector_chip_bg_dark"
                    android:textColor="@color/selector_chip_text_dark"
                    app:chipStrokeColor="@color/selector_chip_stroke_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipIconTint="#FF6B35"
                    app:chipIcon="@drawable/ic_circle" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCritical"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Критичная"
                    app:chipBackgroundColor="@color/selector_chip_bg_dark"
                    android:textColor="@color/selector_chip_text_dark"
                    app:chipStrokeColor="@color/selector_chip_stroke_dark"
                    app:chipStrokeWidth="1dp"
                    app:chipIconTint="#FF4757"
                    app:chipIcon="@drawable/ic_circle" />

            </com.google.android.material.chip.ChipGroup>

            <!-- МЕСТОПОЛОЖЕНИЕ СЕКЦИЯ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Местоположение"
                android:textAppearance="@style/TextAppearance.E68.Subtitle"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- Карточка геолокации -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.E68.Card.Dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGetGps"
                        style="@style/Widget.E68.Button.Secondary.Dark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="Определить GPS"
                        app:icon="@drawable/ic_location"
                        app:iconGravity="textStart" />

                    <TextView
                        android:id="@+id/tvGpsCoords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.E68.Body"
                        android:textColor="@color/primary"
                        android:visibility="gone"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_coords_dark"
                        android:fontFamily="monospace" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Адрес -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAddress"
                style="@style/Widget.E68.TextInputLayout.Dark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Адрес"
                app:startIconDrawable="@drawable/ic_location_on"
                app:startIconTint="@color/primary"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Геокодер кнопки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFindAddress"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Проверить адрес"
                    android:textColor="@color/primary"
                    app:icon="@drawable/ic_search"
                    app:iconTint="@color/primary" />

                <ProgressBar
                    android:id="@+id/progressGeocoder"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ФОТОГРАФИЯ СЕКЦИЯ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Фотография"
                android:textAppearance="@style/TextAppearance.E68.Subtitle"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp" />

            <!-- Кнопки фото -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTakePhoto"
                    style="@style/Widget.E68.Button.Secondary.Dark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="Камера"
                    app:icon="@drawable/ic_camera"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickPhoto"
                    style="@style/Widget.E68.Button.Secondary.Dark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Галерея"
                    app:icon="@drawable/ic_gallery"
                    app:iconGravity="textStart" />

            </LinearLayout>

            <!-- Превью фото карточка -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPhotoPreview"
                style="@style/Widget.E68.Card.Dark"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="16dp"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivPhotoPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemovePhoto"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:text="Удалить"
                        android:textColor="@color/error"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="@color/error" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/bg_gradient_dark" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- КНОПКА СОЗДАНИЯ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    style="@style/Widget.E68.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Создать дефект"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/white"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>