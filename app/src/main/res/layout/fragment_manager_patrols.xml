<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_manager_patrols.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Объезды инспекторов"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/filterButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            app:icon="@drawable/ic_filter"
            app:iconTint="@color/text_secondary"
            app:iconPadding="0dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Фильтр по инспектору -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/inspectorChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAllInspectors"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Все инспекторы"
                android:checked="true"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipActivePatrols"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Активные"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFinishedPatrols"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Завершённые"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Список объездов -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/patrolsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView android:layout_width="80dp" android:layout_height="80dp"
                android:src="@drawable/ic_empty" app:tint="@color/text_hint" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Нет объездов"
                android:textColor="@color/text_secondary" android:textSize="16sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>