<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_admin_users.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Сотрудники"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddUser"
            style="@style/Widget.E68.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="+ Добавить"
            android:textSize="13sp"
            app:cornerRadius="20dp" />
    </LinearLayout>

    <!-- Фильтр по роли -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/roleChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAllRoles"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Все"
                android:checked="true"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipInspectors"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Инспекторы"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipManagers"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Менеджеры"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipActiveUsers"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Активные"
                android:textColor="@color/selector_chip_text"
                app:chipBackgroundColor="@color/selector_chip_bg"
                app:chipStrokeColor="@color/selector_chip_stroke"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Статистика -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/countAllUsers" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="@color/primary" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Всего" android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/status_resolved_bg"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/countActiveUsers" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="@color/status_resolved" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Активных" android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            app:cardBackgroundColor="@color/status_open_bg"
            app:cardCornerRadius="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/countBlockedUsers" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textColor="@color/status_open" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Заблок." android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Список пользователей -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/usersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ImageView android:layout_width="80dp" android:layout_height="80dp"
                android:src="@drawable/ic_empty" app:tint="@color/text_hint" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Сотрудники не найдены"
                android:textColor="@color/text_secondary" android:textSize="16sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>

</LinearLayout>