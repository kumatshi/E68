<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ══════════════ ЗАГОЛОВОК ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Фото-отчёт"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сфотографируйте дефект — остальное заполнится автоматически"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:paddingStart="20dp"
            android:paddingBottom="16dp" />

        <!-- ══════════════ БЛОК ФОТО ══════════════ -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.E68.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <!-- Плейсхолдер когда фото нет -->
                <LinearLayout
                    android:id="@+id/layoutPhotoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/surface">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/text_hint"
                        android:alpha="0.5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Нажмите для съёмки"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Превью сделанного фото -->
                <ImageView
                    android:id="@+id/ivPhotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <!-- Кнопка "Переснять" поверх фото -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetakePhoto"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:text="Переснять"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:backgroundTint="@color/surface" />

            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Кнопка съёмки -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTakePhoto"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="20dp"
            android:text="📷  Сделать фото"
            android:textSize="16sp"
            app:backgroundTint="@color/primary" />

        <!-- ══════════════ ГЕОЛОКАЦИЯ ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="МЕСТОПОЛОЖЕНИЕ"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.E68.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivGpsIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_location_off"
                        app:tint="@color/text_secondary"
                        android:layout_marginEnd="10dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGpsStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ожидание GPS…"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Прогресс GPS -->
                    <ProgressBar
                        android:id="@+id/progressGps"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminate="true"
                        android:visibility="gone" />

                    <!-- Обновить GPS -->
                    <ImageButton
                        android:id="@+id/btnRefreshGps"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_refresh"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="6dp"
                        app:tint="@color/primary" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══════════════ КАТЕГОРИЯ ДЕФЕКТА ══════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="КАТЕГОРИЯ ДЕФЕКТА"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.E68.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipYama"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Яма" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTreshina"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Трещина" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipVyboyina"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Выбоина" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKoleya"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Колея" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipProval"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Провал" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKray"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Разрушение края" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDrugoe"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Другое" />

                </com.google.android.material.chip.ChipGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Ошибка категории -->
        <TextView
            android:id="@+id/tvCategoryError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Выберите категорию дефекта"
            android:textSize="12sp"
            android:textColor="@color/status_open"
            android:paddingStart="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <!-- ══════════════ КНОПКА ОТПРАВКИ ══════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendReport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Отправить отчёт"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/status_resolved"
                app:icon="@drawable/ic_send"
                app:iconGravity="textStart" />

            <ProgressBar
                android:id="@+id/progressSend"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/white"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>
</ScrollView>