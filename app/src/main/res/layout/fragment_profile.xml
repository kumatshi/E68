<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── HEADER: аватар + имя + роль ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="28dp"
            android:background="@color/secondary">

            <!-- Аватар -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_avatar_circle" />

                <TextView
                    android:id="@+id/tvAvatarInitials"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:gravity="center"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:text="ИИ" />

                <!-- Онлайн-индикатор -->
                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_online_dot" />
            </FrameLayout>

            <!-- Имя -->
            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="6dp"
                android:text="Загрузка..." />

            <!-- Роль — цветной бейдж -->
            <TextView
                android:id="@+id/tvProfileRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_role_badge"
                android:layout_marginBottom="6dp"
                android:text="INSPECTOR" />

            <!-- Email -->
            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:text="email@test.com" />
        </LinearLayout>

        <!-- ── СЕКЦИЯ: Информация ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ИНФОРМАЦИЯ"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.E68.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Отдел -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_route"
                        app:tint="@color/primary"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Подразделение"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                        <TextView
                            android:id="@+id/tvDepartment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Участок №1"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="50dp" />

                <!-- Статус аккаунта -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/status_resolved"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Статус аккаунта"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                        <TextView
                            android:id="@+id/tvAccountStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Активен"
                            android:textSize="15sp"
                            android:textColor="@color/status_resolved" />
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="50dp" />

                <!-- UID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/text_hint"
                        android:layout_marginEnd="14dp" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID пользователя"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint" />
                        <TextView
                            android:id="@+id/tvUserId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="12sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/text_secondary"
                            android:maxLines="1"
                            android:ellipsize="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── СЕКЦИЯ: Статистика ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="МОЯ СТАТИСТИКА"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:weightSum="3">

            <!-- Зафиксировано -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.E68.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvStatCreated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Создано"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Устранено -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.E68.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvStatResolved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/status_resolved" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Устранено"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Объездов -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.E68.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="14dp">
                    <TextView
                        android:id="@+id/tvStatPatrols"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Объездов"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── СЕКЦИЯ: Настройки ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="НАСТРОЙКИ"
            android:textSize="11sp"
            android:textColor="@color/text_hint"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.E68.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Уведомления -->
                <LinearLayout
                    android:id="@+id/rowNotifications"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/text_secondary"
                        android:layout_marginEnd="14dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Уведомления"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:theme="@style/SwitchOrange" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="50dp" />

                <!-- Тёмная тема (информационная строка) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_analytics"
                        app:tint="@color/text_secondary"
                        android:layout_marginEnd="14dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Тёмная тема"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Включена"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="50dp" />

                <!-- О приложении -->
                <LinearLayout
                    android:id="@+id/rowAbout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_road"
                        app:tint="@color/text_secondary"
                        android:layout_marginEnd="14dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="О приложении"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:id="@+id/tvAppVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="v1.0.0"
                        android:textSize="13sp"
                        android:textColor="@color/text_hint" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── КНОПКА ВЫЙТИ ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="24dp"
            android:text="Выйти из аккаунта"
            android:textSize="15sp"
            android:textColor="#FF4757"
            app:backgroundTint="#1AFF4757"
            app:strokeColor="#FF4757"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_stop"
            app:iconTint="#FF4757"
            app:iconGravity="textStart" />

        <!-- Версия внизу -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RoadPatrol © 2025"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

    </LinearLayout>
</ScrollView>